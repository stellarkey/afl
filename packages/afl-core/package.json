{
  "name": "@afl/core",
  "version": "0.1.0",
  "description": "AFL (Agent Filesystem Language) core parser and runtime",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
