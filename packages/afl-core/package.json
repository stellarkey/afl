  "keywords": ["afl", "agent", "filesystem", "memory", "markdown"],
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.1.0",
    "@types/node": "^22.0.0"
  },
  "dependencies": {
    "yaml": "^2.7.0"
  }
}
